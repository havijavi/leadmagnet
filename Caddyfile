{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	handle_path /api/* {
		reverse_proxy backend:8000
	}
	handle /docs {
		reverse_proxy backend:8000
	}
	handle /openapi.json {
		reverse_proxy backend:8000
	}
	handle /health {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

# NocoDB on its own subdomain. Skip the block if NOCODB_DOMAIN is unset.
{$NOCODB_DOMAIN} {
	encode gzip zstd
	reverse_proxy nocodb:8080
}
