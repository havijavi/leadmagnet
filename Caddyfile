{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# API + auto-generated OpenAPI docs
	handle_path /api/* {
		reverse_proxy backend:8000
	}
	handle /docs {
		reverse_proxy backend:8000
	}
	handle /openapi.json {
		reverse_proxy backend:8000
	}
	handle /health {
		reverse_proxy backend:8000
	}

	# Everything else → Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
